{
  "name": "reqs-builder",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:4-24",

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/go:1": {},
    "ghcr.io/devcontainers-extra/features/uv:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "editorconfig.editorconfig",
        "redhat.vscode-yaml",
        "bierner.markdown-mermaid",
        "github.vscode-github-actions"
      ]
    }
  },

  "mounts": ["source=reqs-builder-claude-${devcontainerId},target=/home/node/.claude,type=volume"],

  "postCreateCommand": {
    "claude-home": "sudo chown -R node:node /home/node/.claude",
    "claude-code": "npm install -g @anthropic-ai/claude-code",
    "typescript-lsp": "npm install -g typescript typescript-language-server",
    "mcp-language-server": "go install github.com/isaacphi/mcp-language-server@latest",
    "ast-grep": "npm install -g @ast-grep/cli"
  },

  "remoteUser": "node"
}
