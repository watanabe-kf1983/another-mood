{
  "permissions": {
    "allow": [
      "Bash(gh repo view:*)",
      "mcp__language-server__diagnostics",
      "mcp__vitest__set_project_root",
      "mcp__ast-grep__find_code",
      "Bash(sg:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | xargs -I {} sh -c 'echo \"{}\" | grep -qE \"/src/.*\\.(ts|js)$\" && npx prettier --write \"{}\"'"
          }
        ]
      }
    ]
  }
}
