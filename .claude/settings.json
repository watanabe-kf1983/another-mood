{
  "permissions": {
    "allow": [
      "Bash(gh api:*)",
      "Bash(gh pr create:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git mv:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git stash:*)",
      "Bash(ls:*)",
      "Bash(node:*)",
      "Bash(npm install:*)",
      "Bash(npm ls:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npx eslint:*)",
      "Bash(npx prettier:*)",
      "Bash(npx reqs-builder:*)",
      "Bash(npx vitest:*)",
      "Bash(tree:*)",
      "mcp__context7__query-docs",
      "mcp__context7__resolve-library-id"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | xargs -I {} sh -c 'echo \"{}\" | grep -qE \"/src/.*\\.(ts|js)$\" && npx prettier --write \"{}\"'"
          }
        ]
      }
    ]
  }
}
